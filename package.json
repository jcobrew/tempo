{
  "name": "tempo",
  "private": false,
  "version": "0.1.0",
  "description": "Tempo is a macOS focus app with a floating mini timer, local history, and opt-in screenshot strict mode beta.",
  "author": "Tempo",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --host 127.0.0.1 --port 4315 --strictPort",
    "dev:backend": "npm --prefix backend run dev",
    "dev:electron": "wait-on tcp:4315 tcp:8080 && ELECTRON_START_URL=http://127.0.0.1:4315 electron .",
    "build:vision-helper": "node electron/scripts/build-vision-helper.mjs",
    "dev:desktop:live": "npm run build:vision-helper && concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:desktop": "npm run build:vision-helper && concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "tsc -b && vite build",
    "build": "npm run build:vision-helper && npm run build:web",
    "desktop:prod": "npm run build:vision-helper && npm run build:web && electron .",
    "pack:mac": "npm run build:vision-helper && npm run build:web && electron-builder --mac --dir",
    "dist:mac": "npm run build:vision-helper && npm run build:web && electron-builder --mac",
    "dist:mac:arm64": "npm run build:vision-helper && npm run build:web && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run build:vision-helper && npm run build:web && electron-builder --mac --x64",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.jcobrew.tempo",
    "productName": "Tempo",
    "files": [
      "dist/**/*",
      "electron/bin/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "afterSign": "scripts/notarize.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "wait-on": "^9.0.4"
  }
}
